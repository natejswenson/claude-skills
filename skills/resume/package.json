{
  "name": "resume-skill",
  "version": "1.0.0",
  "private": true,
  "description": "Self-contained Claude Code skill that tailors a resume to a job description and renders a polished multi-template PDF. Reading, extraction, and tailoring run agent-native; only PDF rendering and content validation are code.",
  "license": "MIT",
  "author": "Nate Swenson",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/natejswenson/claude-skills.git"
  },
  "homepage": "https://github.com/natejswenson/claude-skills#readme",
  "bugs": {
    "url": "https://github.com/natejswenson/claude-skills/issues"
  },
  "keywords": [
    "claude-code",
    "claude-code-skill",
    "resume",
    "cv",
    "resume-tailoring",
    "pdf",
    "cli"
  ],
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "node scripts/run-tests.mjs",
    "eval": "node --import ./scripts/_tsx-register.mjs scripts/evals/run.mjs",
    "render": "node --import ./scripts/_tsx-register.mjs scripts/render.mjs"
  },
  "dependencies": {
    "@react-pdf/renderer": "^4.5.0",
    "mammoth": "^1.12.0",
    "react": "19.2.4",
    "unpdf": "^1.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "typescript": "^5"
  }
}
