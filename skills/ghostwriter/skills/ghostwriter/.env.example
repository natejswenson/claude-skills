# Copy this file to `.env` and fill in your values. NEVER commit `.env`.
#
# From your LinkedIn developer app (https://www.linkedin.com/developers/apps):
LINKEDIN_CLIENT_ID=your_client_id_here
LINKEDIN_CLIENT_SECRET=your_client_secret_here

# Must EXACTLY match an "Authorized redirect URL" you added in the app's
# Auth tab. The default below is what scripts/linkedin_auth.py listens on.
LINKEDIN_REDIRECT_URI=http://localhost:8765/callback

# --- Filled in automatically by scripts/linkedin_auth.py (do not edit by hand) ---
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=
LINKEDIN_TOKEN_EXPIRES_AT=

# LinkedIn API version (YYYYMM). Bump occasionally; see LinkedIn-Version header docs.
LINKEDIN_API_VERSION=202605
