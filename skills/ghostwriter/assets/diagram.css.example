/* Image brand style guide (TEMPLATE).
 *
 * Copy this to assets/diagram.css and make it yours — palette, fonts, and the
 * --byline below. assets/diagram.css is gitignored (it's YOUR brand, not shared);
 * this .example is the neutral default that ships with the repo.
 */
:root {
  /* ↓↓↓ Set your byline — shown at the bottom of every card and diagram. ↓↓↓ */
  --byline:    "Your Name · yoursite.com";

  --bg:        #0D1117;  /* canvas background (GitHub-dark; reads premium in the feed) */
  --surface:   #161B22;  /* node / panel fill */
  --surface-2: #1F2630;  /* secondary fill */
  --border:    #30363D;  /* hairlines */
  --text:      #E6EDF3;  /* primary text */
  --muted:     #9DA7B3;  /* secondary text */
  --accent:    #58A6FF;  /* primary accent (blue) */
  --accent-2:  #3FB950;  /* secondary accent (green) */
  --accent-3:  #F778BA;  /* tertiary accent (pink) */
  --font: -apple-system, BlinkMacSystemFont, "Segoe UI", Inter, Roboto, Helvetica, Arial, sans-serif;
  --mono: "SF Mono", "JetBrains Mono", "Fira Code", ui-monospace, Menlo, monospace;
}

* { box-sizing: border-box; }
html, body { margin: 0; padding: 0; background: var(--bg); }
body { font-family: var(--font); color: var(--text); -webkit-font-smoothing: antialiased; }

/* ---- Mermaid canvas: scales the diagram to fill a fixed-width brand frame ---- */
#canvas.mermaid-canvas {
  width: 1180px;
  padding: 80px;
  background: var(--bg);
}
#canvas.mermaid-canvas .mermaid {
  background: transparent;
  display: flex;
  justify-content: center;
}
#canvas.mermaid-canvas .mermaid svg {
  width: 100% !important;
  max-width: 100% !important;
  height: auto !important;
}
/* Byline under every diagram (from --byline). */
#canvas.mermaid-canvas::after {
  content: var(--byline);
  display: block;
  margin-top: 44px;
  text-align: right;
  font: 500 24px/1 var(--mono);
  color: var(--muted);
  opacity: 0.85;
}

/* ---- Designed card: a fixed-size hero graphic ---- */
#canvas.card {
  width: 1200px;
  height: 1200px;
  padding: 96px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 36px;
  background:
    radial-gradient(1200px 600px at 85% -10%, rgba(88,166,255,0.16), transparent 60%),
    radial-gradient(900px 500px at -10% 110%, rgba(63,185,80,0.12), transparent 60%),
    var(--bg);
  position: relative;
  overflow: hidden;
}
#canvas.card::after {
  content: "";
  position: absolute; inset: 0;
  border: 1px solid var(--border);
  pointer-events: none;
}

.card .eyebrow {
  font: 600 28px/1.2 var(--mono);
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--accent);
}
.card h1 {
  font: 800 84px/1.04 var(--font);
  letter-spacing: -0.02em;
  margin: 0;
  text-wrap: balance;
}
.card .sub { font: 400 38px/1.4 var(--font); color: var(--muted); margin: 0; }

.card .rows { display: flex; flex-direction: column; gap: 20px; margin-top: 8px; }
.card .row {
  display: flex; align-items: baseline; gap: 20px;
  font: 500 40px/1.3 var(--font);
}
.card .row .key { color: var(--accent-2); font-weight: 700; min-width: 220px; }
.card .row .arrow { color: var(--muted); }

.card .stat { font: 800 140px/1 var(--font); letter-spacing: -0.03em; }
.card .stat .unit { font-size: 56px; color: var(--muted); font-weight: 600; }

/* Footer byline. Use <div class="footer brand"></div> to pull --byline automatically,
   or <div class="footer">custom text</div> for a one-off. */
.card .footer {
  position: absolute; left: 96px; bottom: 72px;
  font: 500 30px/1 var(--mono); color: var(--muted);
}
.card .footer.brand::before { content: var(--byline); }

.card .pill {
  align-self: flex-start;
  background: var(--surface); border: 1px solid var(--border);
  border-radius: 999px; padding: 14px 28px;
  font: 600 30px/1 var(--mono); color: var(--text);
}

/* ---- Date / deadline card TYPE: the date is the hero, keep words minimal ---- */
#canvas.card.date { gap: 22px; justify-content: center; }
.card .date-label {
  font: 600 28px/1.2 var(--mono);
  letter-spacing: 0.16em; text-transform: uppercase;
  color: var(--accent-2);
}
.card .date-hero {
  font: 800 200px/0.9 var(--font);
  letter-spacing: -0.04em; color: var(--text);
  white-space: nowrap;
}
.card .date-sub { font: 500 48px/1.3 var(--font); color: var(--muted); }

/* ---- Ramp card TYPE: ascending steps showing an accelerating progression.
   Bars are illustrative (NOT to scale); the labeled figures carry the truth. ---- */
#canvas.card.ramp { justify-content: center; gap: 0; }
.card.ramp .eyebrow { margin-bottom: 14px; }
.card.ramp h1 { font-size: 64px; margin-bottom: 64px; }
.card .ramp-row {
  display: flex; align-items: flex-end; justify-content: center; gap: 60px;
}
.card .step { display: flex; flex-direction: column; align-items: center; gap: 26px; }
.card .step .val { font: 800 60px/1 var(--font); letter-spacing: -0.02em; color: var(--text); }
.card .step .bar {
  width: 210px; border-radius: 22px 22px 0 0;
  background: var(--surface); border: 1px solid var(--border); border-bottom: none;
}
.card .step.s1 .bar { height: 130px; }
.card .step.s2 .bar { height: 290px; }
.card .step.s3 .bar { height: 470px; background: linear-gradient(180deg, var(--accent) 0%, rgba(88,166,255,0.15) 100%); border-color: var(--accent); }
.card .step.s3 .val { color: var(--accent); }
.card .step .date { font: 600 28px/1 var(--mono); color: var(--muted); }
.card .ramp-base { height: 1px; background: var(--border); margin-top: -1px; }
.card.ramp .kicker { margin-top: 56px; font: 500 40px/1.4 var(--font); color: var(--muted); text-wrap: balance; }
.card.ramp .kicker b { color: var(--text); font-weight: 700; }

/* ---- STEM card TYPE: playful, kid-energy styling for STEM / education / outreach.
   Brighter and more colorful than the other cards on purpose — a chunky toy-block
   S T E M motif, confetti accents, a rounded hero headline. Keep it to one idea. ---- */
#canvas.card.stem {
  --b1: var(--accent);     /* blue   */
  --b2: var(--accent-2);   /* green  */
  --b3: var(--accent-3);   /* pink   */
  --b4: #F2CC60;           /* warm yellow — a playful 4th hue, stem-only */
  justify-content: center;
  gap: 40px;
  background:
    radial-gradient(440px 440px at 12% 16%, rgba(88,166,255,0.30), transparent 60%),
    radial-gradient(480px 480px at 88% 12%, rgba(247,120,186,0.26), transparent 60%),
    radial-gradient(540px 540px at 84% 92%, rgba(63,185,80,0.24), transparent 60%),
    radial-gradient(440px 440px at 10% 90%, rgba(242,204,96,0.24), transparent 62%),
    linear-gradient(160deg, #2B3A7A 0%, #1E2A5E 56%, #182146 100%);
}
/* confetti dots scattered behind the content */
#canvas.card.stem::before {
  content: "";
  position: absolute; inset: 0;
  background-image:
    radial-gradient(circle, var(--accent) 0 9px, transparent 10px),
    radial-gradient(circle, var(--accent-3) 0 7px, transparent 8px),
    radial-gradient(circle, var(--b4) 0 8px, transparent 9px),
    radial-gradient(circle, var(--accent-2) 0 6px, transparent 7px);
  background-position: 130px 980px, 1050px 770px, 980px 250px, 220px 360px;
  background-repeat: no-repeat;
  opacity: 0.75;
  pointer-events: none;
}
.card.stem .blocks { display: flex; gap: 30px; justify-content: flex-start; z-index: 1; }
.card.stem .block {
  width: 150px; height: 150px;
  display: flex; align-items: center; justify-content: center;
  border-radius: 30px;
  font: 800 84px/1 var(--font);
  color: #11183A;
  box-shadow: 0 14px 0 rgba(0,0,0,0.22), inset 0 5px 0 rgba(255,255,255,0.38);
}
.card.stem .block.b1 { background: var(--b1); transform: rotate(-6deg); }
.card.stem .block.b2 { background: var(--b2); transform: rotate(4deg); }
.card.stem .block.b3 { background: var(--b3); transform: rotate(-3deg); }
.card.stem .block.b4 { background: var(--b4); transform: rotate(7deg); }
.card.stem .eyebrow {
  align-self: flex-start; z-index: 1;
  background: rgba(255,255,255,0.10);
  border: 1px solid rgba(255,255,255,0.20);
  border-radius: 999px; padding: 12px 28px;
  color: #FFFFFF;
}
.card.stem h1 { font-size: 92px; color: #FFFFFF; z-index: 1; }
.card.stem .kicker {
  margin: 0; z-index: 1;
  font: 500 42px/1.4 var(--font); color: rgba(255,255,255,0.80); text-wrap: balance;
}
.card.stem .kicker b { color: #FFFFFF; font-weight: 800; }
.card.stem .footer { color: rgba(255,255,255,0.62); z-index: 1; }
