# Secrets — never commit
.env

# Local per-user Claude settings
.claude/settings.local.json

# Personal data exports & generated posts (keep the dirs, ignore contents)
data/*
!data/.gitkeep
drafts/*
!drafts/.gitkeep

# Personal voice files — copy the *.example.md versions and fill these in
voice/interests.md
voice/voice-notes.md
voice/voice-profile.md

# Release-radar digests + log (research artifacts, keep local)
research/*
!research/.gitkeep

# Python
__pycache__/
*.pyc
.venv/
venv/

# OS
.DS_Store
